{
  "name": "mikejw/elib-cms",
  "type": "library",
  "description": "ELib CMS",
  "keywords": [
    "lib"
  ],
  "homepage": "https://empathy.sh",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael J. Whiting",
      "email": "mail@mikejw.co.uk"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/mikejw/alice"
    }
  ],
  "require": {
    "mikejw/elib-base": "^4",
    "michelf/php-markdown": "1.9.1"
  },
  "require-dev": {
    "nelmio/alice": "dev-2.x-dev",
    "pestphp/pest": "^4.4"
  },
  "autoload": {
    "psr-0": {
      "Empathy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "pest": "pest",
    "test": "phpunit -c ./phpunit.xml"
  },
  "minimum-stability": "dev",
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
